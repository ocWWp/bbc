# Copy this file to .env.local and fill in the values.
# .env.local is gitignored.

# === Supabase Auth ===
# From https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Used for admin ops (e.g. auth.admin.inviteUserByEmail).
# DO NOT expose client-side. From the same Supabase project settings page.
SUPABASE_SERVICE_ROLE_KEY=

# === Tenant repo location (file-mode) ===
# Path to the tenant repo whose memory/, queue/, _log/, bindings.yaml the
# dashboard reads. Two common values:
#   - examples/example-tenant   (the Acme Co demo, BBC's default)
#   - /path/to/your-tenant-repo (your own forked tenant repo)
# Unset = same as examples/example-tenant. See docs/tenant-repo-architecture.md.
# BBC_REPO=examples/example-tenant

# === Storage mode (optional) ===
# file (default) — read tenant content from BBC_REPO filesystem, write via bash scripts.
# db             — read/write the tenant's Supabase rows (multi-tenant SaaS path).
# BBC_MODE=file

# === Tenant invitations ===
# Sign-up gating moved into the public.tenant_invitations table.
# Seed it via SQL — see supabase/migrations/0004_*.sql for the schema and
# docs/operating-bbc.md for how to issue your first invitation.

# === Signup mode (self-service) ===
# invite_only (default) — only emails in tenant_invitations can sign up
# open                  — strangers can sign up via /auth/self-serve and get their own tenant
# BBC_SIGNUP_MODE=invite_only

# === Auto-confirm signup ===
# false (default, prod-safe) — Supabase sends a confirmation email; user clicks link before signin
# true                       — bypass email confirmation. Needed for dev when no SMTP wired.
#                              In prod this lets anyone spoof signup with an email they don't own.
# BBC_SIGNUP_AUTOCONFIRM=false

# === Resend (email send) ===
# Optional. When unset, invitation emails are logged to the server console
# instead of being sent. To actually send:
#   1. Sign up at https://resend.com (free tier: ~100 emails/day)
#   2. Verify your sending domain
#   3. Create an API key
#   4. Set both vars below
# RESEND_API_KEY=re_…
# RESEND_FROM=BBC <onboarding@your-domain.com>
# RESEND_FROM_EMAIL takes precedence over RESEND_FROM if both are set.
# RESEND_FROM_EMAIL=BBC <hello@bbc.tools>

# === OAuth providers (optional) ===
# Comma-separated list of OAuth providers ENABLED in your Supabase project.
# Buttons appear on /auth/signin only for providers listed here. Default: none
# (only email/password). Currently supported: github, google.
# To enable a provider:
#   1. Register an OAuth app at the vendor (e.g., github.com/settings/developers)
#      with callback https://<project-ref>.supabase.co/auth/v1/callback
#   2. Paste Client ID + Secret in Supabase dashboard → Authentication → Providers
#   3. Add the provider name here (lowercase)
# BBC_OAUTH_PROVIDERS=github,google

# === OAuth state HMAC (Phase K — connector OAuth) ===
# OAuth state HMAC signing — generate with `openssl rand -base64 32`
# REQUIRED if any OAuth connector (gmail, drive) is installed. Empty/unset
# causes /api/oauth/* routes to refuse to boot (Cloudflare unset env = "").
BBC_OAUTH_STATE_SECRET=

# === Sentry (error monitoring) ===
# Leave blank in dev — Sentry only initializes when NODE_ENV=production.
# In production, set the DSN; org/project/authToken enable source map upload.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# === Anthropic (onboarding extractor — Claude Sonnet 4.6) ===
# From https://console.anthropic.com/settings/keys
# Used by /welcome to extract typed memory proposals from brain-dump text.
ANTHROPIC_API_KEY=

# === PostHog (product analytics, consent-gated) ===
# Leave blank in dev. PostHog only initializes for users who accept the cookie banner.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_API_KEY=
