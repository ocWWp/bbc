# Copy this file to .env.local and fill in the values.
# .env.local is gitignored.

# === Supabase Auth ===
# From https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Used for admin ops (e.g. auth.admin.inviteUserByEmail).
# DO NOT expose client-side. From the same Supabase project settings page.
SUPABASE_SERVICE_ROLE_KEY=

# === BBC repo location ===
# Server-side fs reads + scripts/{accept,reject}.sh invocations.
# Default: sibling at ../bbc relative to this repo. Override if elsewhere.
# BBC_REPO=/Users/grid/Documents/GitHub/bbc

# === Allowlist ===
# The allowlist is now stored in Supabase (table: public.allowlist).
# Seed it via SQL — see supabase/migrations/0001_dashboard_auth_init.sql.
# No env var needed.
