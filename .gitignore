# Per-host runtime state (regenerated by daemons; see scripts/install-daemons.sh)
_log/heartbeat
_log/*.tmp
_log/refresh-*

# Per-leaf local-only notes (per "local-only knowledge" convention in distribution/<leaf>/CLAUDE.md)
distribution/*/local/

# Claude Code session-local settings (per-developer)
.claude/settings.local.json

# Environment files — none should ever be committed; .env.example is the only checked-in template
.env
.env.*
!.env.example

# Docker build cache (large)
.docker-cache/

# Cloudflare / OpenNext build artifacts (regenerated by `pnpm cf:build`)
.open-next/
.wrangler/

# Next.js build output
.next/
.vercel/

# Editor / OS junk
.DS_Store
.AppleDouble
.LSOverride
*.swp
*.swo
.vscode/
.idea/
node_modules
.playwright-mcp/
