# BBC self-host — root env file consumed by docker-compose.yml
# Copy this to `.env` (gitignored) at the repo root and fill in real values.
#
# These are the same Supabase env vars the dashboard needs in
# `apps/dashboard/.env.local` for local dev. The docker-compose stack
# reads them from this root .env.

# === Supabase Auth + DB ===
# Either: a remote Supabase project (https://supabase.com/dashboard/project/<ref>/settings/api)
# Or:     a local supabase stack (`supabase start` in apps/dashboard/, then copy printed values)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Tenant repo path (file-mode) ===
# Path on the HOST machine to mount as /app/tenant inside the container.
# Defaults to ./examples/example-tenant for the Acme demo.
# BBC_REPO_HOST_PATH=/path/to/your-tenant-repo

# === Storage mode ===
# file (default) — read tenant content from BBC_REPO filesystem
# db             — read/write Supabase rows (multi-tenant SaaS path)
BBC_MODE=file

# === Signup mode ===
# invite_only (default) — signup requires a pre-existing tenant_invitations row
# open                  — strangers can sign up via /auth/self-serve and get their own tenant
BBC_SIGNUP_MODE=invite_only

# === Auto-confirm signup ===
# false (default, prod-safe) — Supabase sends a confirmation email; user clicks link before signin.
# true                       — bypass email confirmation. Needed for dev when no SMTP wired.
#                              In prod this lets anyone spoof signup with an email they don't own.
BBC_SIGNUP_AUTOCONFIRM=false

# === AI provider (BYOK preferred) ===
# Optional. If unset, every tenant must add their own Anthropic key at
# /settings/keys before they can run the Studio or onboarding extractor.
# When set, this key acts as the shared hosted-demo fallback (capped via
# BBC_HOSTED_DEMO_MODE).
ANTHROPIC_API_KEY=

# === Hosted-demo flag ===
# true  — the welcome banner nudges users to bring their own key first.
# false — assume self-host; env-var fallback is the intended path.
BBC_HOSTED_DEMO_MODE=false

# === BYOK encryption key ===
# REQUIRED to use /settings/keys. 32 raw bytes, base64-encoded.
# Generate with:  openssl rand -base64 32
# Rotating this value invalidates every stored tenant key. No rotation tooling
# in v1 -- pick a value, store it in your secrets manager, never rotate.
BBC_SECRET_ENCRYPTION_KEY=

# === Email (optional) ===
# Wires invite + signup + queue-digest transactional email via Resend.
# Leave empty to skip emails; flows that need them will fail loudly.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# === Analytics (optional) ===
# PostHog product analytics. Leave empty to disable.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Error tracking (optional) ===
# SENTRY_DSN=

